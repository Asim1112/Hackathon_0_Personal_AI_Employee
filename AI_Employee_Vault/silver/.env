# Silver AI Employee — Environment Variables
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to git (it's in .gitignore)

# ── Vault ────────────────────────────────────────────────────────────────────
# Absolute path to the silver vault root (used by MCP servers)
VAULT_PATH=/absolute/path/to/silver

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=asimhussain787@gmail.com
LINKEDIN_PASSWORD=sydney7287..

# Set to false to see the browser window (useful for first login / CAPTCHA)
HEADLESS=false

# ── Email MCP (SMTP) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=asimhussain787@gmail.com
SMTP_PASS=kadf udfj ajna kqrx
SMTP_FROM="Your Name <your.email@gmail.com>"

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# No credentials needed — auth is via QR scan (session saved to whatsapp_session/)
# First run: python whatsapp_watcher.py --no-headless  (scan QR code)
# After that: runs headlessly via scheduler.py

# ── Scheduler ─────────────────────────────────────────────────────────────────
GMAIL_INTERVAL=120      # seconds between Gmail polls
LINKEDIN_INTERVAL=300   # seconds between LinkedIn polls
WHATSAPP_INTERVAL=30    # seconds between WhatsApp Web polls
