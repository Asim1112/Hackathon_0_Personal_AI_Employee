# Odoo MCP Server — Environment Variables
# These are read from the vault-root .env (../../.env), not this file.
# Copy ../../.env.example to ../../.env and fill in the Odoo section.

ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee
ODOO_USERNAME=admin@example.com
ODOO_PASSWORD=admin

# Set to true to log actions without executing them (safe for testing)
DRY_RUN=false
