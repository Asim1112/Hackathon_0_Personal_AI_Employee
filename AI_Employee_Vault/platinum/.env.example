# =============================================================================
# platinum/.env.example
# Copy this to .env and fill in real values on EACH machine separately.
# NEVER commit .env to Git.
# Cloud VM and Local machine each have their OWN .env with different values.
# =============================================================================

# --- AGENT IDENTITY (change per machine) ------------------------------------
# On Cloud VM:  AGENT_ID=cloud_agent
# On Windows:   AGENT_ID=local_agent
AGENT_ID=cloud_agent

# --- ANTHROPIC (Claude Code — required on BOTH machines) --------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- GMAIL (credentials.json goes in platinum/ dir — NOT committed to Git) --
# Copy credentials.json manually to each machine via scp.
# Run watcher once to generate token.json (OAuth consent).
# No env vars needed for Gmail — it uses credentials.json + token.json.

# --- TWITTER/X ---------------------------------------------------------------
TWITTER_BEARER_TOKEN=your-bearer-token
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
TWITTER_INTERVAL=300

# --- LINKEDIN (Cloud VM only — browser automation) ---------------------------
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
LINKEDIN_INTERVAL=300
HEADLESS=true

# --- FACEBOOK / INSTAGRAM ----------------------------------------------------
FACEBOOK_ACCESS_TOKEN=your-long-lived-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id
FACEBOOK_INTERVAL=600

# --- EMAIL SEND (Local machine ONLY — never on Cloud VM) --------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# --- GIT SYNC ----------------------------------------------------------------
# Use SSH remote (recommended): git@github.com:yourusername/AI_Employee_Vault.git
# Or HTTPS: https://github.com/yourusername/AI_Employee_Vault.git
GITHUB_REMOTE=git@github.com:yourusername/AI_Employee_Vault.git
GITHUB_BRANCH=main

# --- ORCHESTRATOR TUNING -----------------------------------------------------
GMAIL_INTERVAL=120
CLAUDE_TIMEOUT=600
WATCHDOG_INTERVAL=30
HEARTBEAT_STALE_MINUTES=30
